# ---------------------------------------------------------------------------
# Database (single direct PostgreSQL connection).
# A pgbouncer pooler + DIRECT_URL split will be introduced in a later phase.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:<password>@77.37.74.7:5432/qirop"

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS="12"

# ---------------------------------------------------------------------------
# Server / CORS
# ---------------------------------------------------------------------------
CLIENT_ORIGIN="http://localhost:5173"
PORT="4000"
NODE_ENV="development"

# Auth-cookie Secure flag: "auto" (Secure in production), "true", or "false".
# Set "false" ONLY when serving production over plain HTTP (bare-IP VPS, no
# domain/TLS yet) — otherwise browsers drop the cookie and logins won't stick.
# Switch back to "auto" the day you add a domain + HTTPS.
COOKIE_SECURE="auto"

# ---------------------------------------------------------------------------
# Seed: initial SUPERADMIN account (change before any real deployment)
# ---------------------------------------------------------------------------
SUPERADMIN_CNIC="00000-0000000-0"
SUPERADMIN_PASSWORD="ChangeMe#123"
SUPERADMIN_NAME="School Owner"

# Set to "true" to also seed one sample teacher/parent/student for testing.
SEED_SAMPLE="false"

# ---------------------------------------------------------------------------
# FileStore (external file-storage service). Obtain a token via POST /apps/create.
# The token must live ONLY on the server, never exposed to the browser.
# ---------------------------------------------------------------------------
FILESTORE_URL="https://file-upload.nakson.services"
FILESTORE_TOKEN="fst_xxxxxxxx"
FILESTORE_APP_ID="<your app id>"
