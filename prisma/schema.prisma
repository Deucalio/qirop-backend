// Qirop School of Wisdom & Technology — ERP database schema
// Money is always Decimal(10,2). IDs are cuid(). Every model carries timestamps.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // single direct connection (pgbouncer to be added later)
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  SUPERADMIN
  ADMIN
  TEACHER
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

// Pakistan's four major academic milestones (SSC → HSSC → BS → MS).
enum QualificationLevel {
  MATRICULATION
  INTERMEDIATE
  BACHELOR
  MASTERS
}

// How a qualification's score is recorded.
enum MarkingType {
  CGPA   // obtained/total CGPA (typically Bachelor/Masters)
  MARKS  // obtained/total marks with percentage
  TEXT   // legacy free-text (backward compat)
}

enum ChallanStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  ADVANCE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum SalaryStatus {
  PENDING
  PAID
}

enum FeeItemType {
  TUITION
  TRANSPORT
  ADMISSION
  EXAM
  OTHER
}

enum ExpenseCategory {
  RENT
  UTILITIES
  MAINTENANCE
  SALARIES
  SUPPLIES
  TRANSPORT
  OTHER
}

enum PermissionModule {
  SCHOOL_SETUP
  USERS
  STUDENTS
  PARENTS
  STAFF
  CLASSES
  ATTENDANCE
  HOMEWORK
  FEES
  EXPENSES
  SALARIES
  REPORTS
  TIMETABLE // sub-permission of CLASSES in the UI (weekly section timetables)
}

// School days for the weekly timetable (Mon–Sat; Sunday off).
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

// ============================================================================
// Identity & Access
// ============================================================================

model User {
  id           String     @id @default(cuid())
  cnic         String     @unique // format XXXXX-XXXXXXX-X
  passwordHash String
  role         Role
  status       UserStatus @default(ACTIVE)
  fullName     String
  phone        String?
  avatarUrl    String?
  lastLoginAt  DateTime?

  // Self-relation: who created this user
  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  // Profiles / permissions
  teacherProfile   TeacherProfile?
  parentProfile    ParentProfile?
  adminPermissions AdminPermission[]

  // Reverse relations for actor references elsewhere
  feePaymentsReceived  FeePayment[]   @relation("FeePaymentReceivedBy")
  feePaymentsReversed  FeePayment[]   @relation("FeePaymentReversedBy")
  expensesRecorded     Expense[]      @relation("ExpenseRecordedBy")
  expensesFunded       ExpenseFunding[] @relation("ExpenseFundedBy")
  salarySlipsGenerated SalarySlip[]   @relation("SalarySlipGeneratedBy")
  notifications           Notification[]      @relation("NotificationTargetUser")
  markedStudentAttendance StudentAttendance[] @relation("StudentAttendanceMarkedBy")
  markedTeacherPeriodAttendance TeacherPeriodAttendance[] @relation("TeacherPeriodAttendanceMarkedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdById])
}

model AdminPermission {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    PermissionModule
  canView   Boolean          @default(false)
  canEdit   Boolean          @default(false)
  canManage Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, module])
  @@index([userId])
}

// ============================================================================
// School profile (single row)
// ============================================================================

model School {
  id           String  @id @default(cuid())
  name         String  @default("Qirop School of Wisdom & Technology")
  logoUrl      String?
  address      String?
  phone        String?
  email        String?
  academicYear String
  settings     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Staff & Parent profiles
// ============================================================================

model TeacherProfile {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId    String     @unique
  gender        Gender
  qualification String?
  address       String?
  joiningDate   DateTime
  salary        Decimal    @db.Decimal(10, 2) // never returned to TEACHER role
  status        UserStatus @default(ACTIVE)

  // Teacher's parent (father/mother) — required for Pakistani employment records.
  fatherName    String     // e.g. "Muhammad Ali"
  parentCnic    String?    // optional parent CNIC

  teachingAssignments  TeachingAssignment[]
  classTeacherSections Section[]            @relation("SectionClassTeacher")
  teacherAttendance    TeacherAttendance[]
  periodAttendance     TeacherPeriodAttendance[]
  homework             Homework[]
  salarySlips          SalarySlip[]
  qualifications       TeacherQualification[]

  // Students whose parent is this staff member (their fees bill to this salary).
  staffChildren       Student[]    @relation("StaffChildren")
  teacherBilledChallans FeeChallan[] @relation("TeacherBilledChallans")

  // At most one transport route (own commute → salary deduction).
  transportAssignment TransportAssignment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// One row per academic milestone (board/university, year, marks, grade/division).
model TeacherQualification {
  id          String             @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  level       QualificationLevel
  institution String // board (Matric/Inter) or university (Bachelor/Masters)
  passingYear Int
  marks       String? // legacy free-text (kept for backward compat)
  grade       String? // grade or division, e.g. "A+", "1st Division"

  // Structured grading — CGPA (Bachelor/Masters) or total/obtained marks.
  markingType   MarkingType @default(TEXT)
  obtainedMarks Decimal?    @db.Decimal(7, 2) // e.g. 850.00 or 3.50
  totalMarks    Decimal?    @db.Decimal(7, 2) // e.g. 1100.00 or 4.00

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, level])
  @@index([teacherId])
}

model ParentProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation String?
  address    String?

  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Academic structure
// ============================================================================

model Class {
  id    String @id @default(cuid())
  name  String @unique // e.g. "Class 5"
  order Int

  sections      Section[]
  classSubjects ClassSubject[]
  feeStructure  FeeStructure?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model Section {
  id   String @id @default(cuid())
  name String // e.g. "A"
  // A class that isn't split into sections still needs somewhere to hang its
  // students, timetable and attendance, so it gets one implicit section. The UI
  // hides section wording for these; naming a real section converts it.
  isDefault      Boolean         @default(false)
  classId        String
  class          Class           @relation(fields: [classId], references: [id], onDelete: Restrict)
  classTeacherId String?
  classTeacher   TeacherProfile? @relation("SectionClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)

  students              Student[]
  teachingAssignments   TeachingAssignment[]
  studentAttendance     StudentAttendance[]
  homework              Homework[]
  timetableSlots        TimetableSlot[]
  teacherPeriodAttendance TeacherPeriodAttendance[]

  // How long the weekly timetable pattern keeps repeating. Set when the first
  // slot is scheduled (defaults to one week); `timetableUntil` null = no end date.
  timetableFrom  DateTime? // canonical PKT day
  timetableUntil DateTime? // canonical PKT day; null = repeats indefinitely

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
  @@index([classId])
  @@index([classTeacherId])
}

model Subject {
  id   String @id @default(cuid())
  name String @unique

  // Hex colour chosen by the admin (e.g. "#6366f1"). Null falls back to a
  // built-in palette slot picked by alphabetical rank, so untouched subjects
  // still get stable, distinct colours.
  colorHex String?

  classSubjects           ClassSubject[]
  teachingAssignments     TeachingAssignment[]
  homework                Homework[]
  timetableSlots          TimetableSlot[]
  teacherPeriodAttendance TeacherPeriodAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Timetable (weekly per-section grid; repeats every week)
// ============================================================================

// One scheduled lesson cell: section × day × period → subject. The teacher is
// resolved through TeachingAssignment(sectionId, subjectId) so reassignments
// automatically flow through. Period timings come from School.settings.
model TimetableSlot {
  id          String    @id @default(cuid())
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  day         DayOfWeek
  periodIndex Int // 1-based, within the school-wide period template
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  // Combined class: sections taught together in one room share a groupId, so the
  // same teacher at the same time across them is intentional, not a clash. Each
  // section still owns its own row, keeping per-section queries unchanged.
  groupId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, day, periodIndex])
  @@index([sectionId])
  @@index([subjectId])
  @@index([groupId])
}

// Per-period teacher attendance for a calendar date, marked against the
// timetable. Denormalized (section/subject) so history survives timetable edits.
model TeacherPeriodAttendance {
  id          String           @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date        DateTime // canonical PKT day
  periodIndex Int
  sectionId   String
  section     Section          @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  subjectId   String
  subject     Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  status      AttendanceStatus
  markedById  String
  markedBy    User             @relation("TeacherPeriodAttendanceMarkedBy", fields: [markedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A teacher can only be in one place per period per day.
  @@unique([teacherId, date, periodIndex])
  @@index([date])
  @@index([sectionId])
  @@index([teacherId])
}

model ClassSubject {
  id        String  @id @default(cuid())
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

// One teacher teaches a given subject in a given section.
// Different sections of a class may have different teachers for the same subject.
model TeachingAssignment {
  id        String         @id @default(cuid())
  sectionId String
  section   Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, subjectId])
  @@index([sectionId])
  @@index([subjectId])
  @@index([teacherId])
}

// ============================================================================
// Students
// ============================================================================

model Student {
  id            String     @id @default(cuid())
  admissionNo   String     @unique
  rollNo        String?
  firstName     String
  lastName      String
  gender        Gender
  dob           DateTime?
  admissionDate DateTime
  photoUrl      String?
  status        UserStatus @default(ACTIVE)

  sectionId String
  section   Section       @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  parentId  String
  parent    ParentProfile @relation(fields: [parentId], references: [id], onDelete: Restrict)

  // Recurring monthly fee concession (sibling/staff/scholarship), applied at
  // challan generation. discountNote records why it exists.
  feeDiscount  Decimal @db.Decimal(10, 2) @default(0)
  discountNote String?

  // When this student's parent is a staff member, their challans (except
  // admission) are billed to the teacher's salary rather than collected in cash.
  teacherParentId String?
  teacherParent   TeacherProfile? @relation("StaffChildren", fields: [teacherParentId], references: [id], onDelete: SetNull)

  attendance StudentAttendance[]
  challans   FeeChallan[]
  payments   FeePayment[]

  // At most one transport route (see TransportAssignment).
  transportAssignment TransportAssignment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, rollNo]) // roll number unique within a section (nulls allowed)
  @@index([sectionId])
  @@index([parentId])
  @@index([teacherParentId])
  @@index([status])
}

// ============================================================================
// Attendance
// ============================================================================

model StudentAttendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId  String // denormalized for fast per-section queries
  section    Section          @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  date       DateTime
  status     AttendanceStatus
  markedById String // the User (teacher or admin) who marked this record
  markedBy   User             @relation("StudentAttendanceMarkedBy", fields: [markedById], references: [id], onDelete: Restrict)
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date])
  @@index([sectionId])
  @@index([studentId])
  @@index([markedById])
}

model TeacherAttendance {
  id          String           @id @default(cuid())
  teacherId   String
  teacher     TeacherProfile   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date        DateTime
  status      AttendanceStatus
  checkInTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, date])
  @@index([date])
  @@index([teacherId])
}

// ============================================================================
// Homework (scoped to section + subject)
// ============================================================================

model Homework {
  id            String         @id @default(cuid())
  sectionId     String
  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  title         String
  description   String
  dueDate       DateTime
  attachmentUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([dueDate])
}

// ============================================================================
// Fees
// ============================================================================

model FeeStructure {
  id           String  @id @default(cuid())
  classId      String  @unique
  class        Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  monthlyFee   Decimal @db.Decimal(10, 2)
  admissionFee Decimal @db.Decimal(10, 2) @default(0) // one-time, added to a student's first challan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One challan per student per month, system-generated. baseAmount/discount are
// SNAPSHOTS taken at generation — later fee-structure changes never alter an
// existing challan.
model FeeChallan {
  id         String        @id @default(cuid())
  challanNo  String        @unique // e.g. CH-2025-000123
  studentId  String
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year       Int
  month      Int // 1..12
  baseAmount Decimal       @db.Decimal(10, 2) @default(0) // = sum(items) at generation
  discount   Decimal       @db.Decimal(10, 2) @default(0) // snapshot (recurring + per-challan)
  lateFee    Decimal       @db.Decimal(10, 2) @default(0)
  amount     Decimal       @db.Decimal(10, 2) // payable = baseAmount − discount + lateFee
  issueDate  DateTime      @default(now())
  dueDate    DateTime
  status     ChallanStatus @default(UNPAID)

  // Staff-child billing: fees (minus admission) are absorbed by the teacher's
  // salary. staffCovered is how much the salary has actually absorbed so far.
  billedToTeacherId String?
  billedToTeacher   TeacherProfile? @relation("TeacherBilledChallans", fields: [billedToTeacherId], references: [id], onDelete: SetNull)
  staffCovered      Decimal         @db.Decimal(10, 2) @default(0)

  items       FeeChallanItem[]
  allocations FeePaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, year, month])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@index([billedToTeacherId])
}

// A single line on a challan (Tuition, Transport, Admission, Exam, Other).
model FeeChallanItem {
  id        String      @id @default(cuid())
  challanId String
  challan   FeeChallan  @relation(fields: [challanId], references: [id], onDelete: Cascade)
  type      FeeItemType
  label     String // display, e.g. "Monthly Tuition", "Route 1 Transport"
  amount    Decimal     @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([challanId])
}

// Safe sequential challan numbers, per calendar year.
model ChallanCounter {
  year       Int @id
  lastNumber Int @default(0)

  updatedAt DateTime @updatedAt
}

// A single received transaction.
model FeePayment {
  id           String        @id @default(cuid())
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount       Decimal       @db.Decimal(10, 2) // total received in this transaction
  paymentDate  DateTime
  method       PaymentMethod
  receivedById String
  receivedBy   User          @relation("FeePaymentReceivedBy", fields: [receivedById], references: [id], onDelete: Restrict)
  note         String?

  // Corrections are explicit, audited reversals — the row is retained forever.
  isReversed     Boolean   @default(false)
  reversedAt     DateTime?
  reversedById   String?
  reversedBy     User?     @relation("FeePaymentReversedBy", fields: [reversedById], references: [id], onDelete: SetNull)
  reversalReason String?

  allocations FeePaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([paymentDate])
  @@index([receivedById])
}

// Splits a payment across one or more challans (partial / advance / carry-forward).
model FeePaymentAllocation {
  id            String     @id @default(cuid())
  paymentId     String
  payment       FeePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  challanId     String
  challan       FeeChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  amountApplied Decimal    @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([paymentId, challanId])
  @@index([paymentId])
  @@index([challanId])
}

// ============================================================================
// Salaries & Expenses (admin-only)
// ============================================================================

model SalarySlip {
  id            String         @id @default(cuid())
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  year          Int
  month         Int
  basicSalary   Decimal        @db.Decimal(10, 2)
  allowances    Decimal        @default(0) @db.Decimal(10, 2)
  deductions    Decimal        @default(0) @db.Decimal(10, 2)
  // This month's teacher-child fees + own transport absorbed by the salary,
  // capped so netSalary never goes below 0 (§7.3). Uncovered fee stays payable
  // on the child's challan — there is NO cross-month salary carry.
  staffFeeDeduction Decimal     @default(0) @db.Decimal(10, 2)
  notes         String? // human explanation of the staff-fee deduction, shown on the slip
  netSalary     Decimal        @db.Decimal(10, 2)
  status        SalaryStatus   @default(PENDING)
  paidDate      DateTime?
  generatedById String
  generatedBy   User           @relation("SalarySlipGeneratedBy", fields: [generatedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, year, month])
  @@index([teacherId])
  @@index([status])
}

model Expense {
  id            String          @id @default(cuid())
  category      ExpenseCategory
  title         String
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime
  note          String?
  attachmentUrl String?
  recordedById  String
  recordedBy    User            @relation("ExpenseRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  // Who actually paid for this expense (sum must equal `amount`).
  funding ExpenseFunding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([date])
  @@index([recordedById])
}

// One funding source for an expense (school cash/bank, someone's own pocket, …).
// The rows for an expense always sum to the expense amount.
model ExpenseFunding {
  id        String    @id @default(cuid())
  expenseId String
  expense   Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  payerType PayerType
  payerId   String? // → User, when a specific person paid from their own pocket
  payer     User?     @relation("ExpenseFundedBy", fields: [payerId], references: [id], onDelete: SetNull)
  amount    Decimal   @db.Decimal(10, 2)
  remarks   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseId])
  @@index([payerId])
}

enum PayerType {
  SCHOOL_CASH
  SCHOOL_BANK
  ADMIN_PERSONAL
  TEACHER_PERSONAL
  OTHER
}

// ============================================================================
// Notifications & Audit
// ============================================================================

model Notification {
  id           String  @id @default(cuid())
  title        String
  body         String
  type         String?
  targetRole   Role?
  targetUserId String?
  targetUser   User?   @relation("NotificationTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  isRead       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetUserId])
  @@index([targetRole])
  @@index([isRead])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())

  // Actor Info
  actorId     String?
  actorName   String   @default("System Admin")
  actorRole   Role     @default(ADMIN)

  // Action Classification
  action      String   // CREATE, UPDATE, DELETE, ATTENDANCE, PAYMENT, DISCOUNT, REVERSAL, RESET, LOGIN
  module      String   @default("GENERAL") // STUDENTS, STAFF, ATTENDANCE, TIMETABLE, FEES, SALARIES, EXPENSES, USERS, SCHOOL

  // Target Entity Info
  targetType  String   @default("System") // Student, Teacher, ClassSection, FeeChallan, SalarySlip, Expense, User, SchoolSetting
  targetId    String?
  targetLabel String   @default("System Record") // e.g. "Ali Ahmed (STD-101)"

  // Detailed Summary & Snapshot Diffs
  details     String   @default("Action recorded in system history") // Human-readable summary
  changes     Json?    // { before: { phone: "..." }, after: { phone: "..." } }

  // Metadata
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([module])
  @@index([action])
  @@index([actorId])
  @@index([actorRole])
  @@index([timestamp])
}

// ---- Phase 5C: Transport ----

// A transport route/van the school runs, with its flat monthly fee.
model TransportRoute {
  id          String  @id @default(cuid())
  name        String // "Route 1 — Gulberg"
  monthlyFee  Decimal @db.Decimal(10, 2)
  vehicleInfo String? // "Hiace · LEB-1234"
  driverName  String?
  driverPhone String?
  stops       String? // free text / comma list (optional)
  active      Boolean @default(true)

  assignments TransportAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// Links exactly ONE person (a student OR a teacher) to a route. The @unique on
// each id enforces "at most one route per person". Student riders → a TRANSPORT
// line on their challan (or their staff-parent's salary); teacher riders → their
// own salary deduction (Phase 5B payroll).
model TransportAssignment {
  id      String         @id @default(cuid())
  routeId String
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Restrict)

  studentId String?         @unique
  student   Student?        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String?         @unique
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routeId])
}

